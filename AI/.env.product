# ==========================================
# CẤU HÌNH PRODUCTION CHO AI WORKER
# Copy file này thành `.env` bên trong thư mục AI
# ==========================================

# Chuỗi kết nối Database
DATABASE_URL=postgresql+asyncpg://postgres:mat_super_secret_2026@db:5432/cars

# Chuỗi kết nối RabbitMQ
RABBITMQ_URL=amqp://matgroup_rmq:matgroup_rmq123@rabbitmq:5672/

# (Tuỳ chọn) Nếu sử dụng Ollama hoặc Gemini
DOMAIN_OLLAMA=http://192.168.1.99:11434
MODEL_NAME=llama3.2:latest
GEMINI_API_KEY=your_gemini_api_key_here

# Thư mục lưu trữ model AI (sử dụng chung cho AI Worker và API)
# LƯU Ý: Nếu đổi thư mục này, BẮT BUỘC phải đổi đích mount volume 'ai_models_cache' trong docker-compose.yml
AI_MODELS_DIR=/app/ai_models
